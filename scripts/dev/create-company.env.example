# ============================================================================
# create-company.sh — local config template
# ============================================================================
# Copy this file to `create-company.env` (gitignored) and edit values, then
# just run `./scripts/dev/create-company.sh`. Inline env vars on the command
# line still override anything here.
#
# Lines starting with `#` are comments. Quote values that contain spaces.
# ============================================================================

# ── Target ──────────────────────────────────────────────────────────────────
# linked (default) : auto-derives URL + service-role key from the
#                    `supabase link` state in supabase/.temp/project-ref.
#                    Requires `supabase login`. One-key [y/N] prompt before
#                    writing (set AUTO_CONFIRM=true to skip — CI only).
# local            : reads URL + service-role key from `supabase status`
#                    (your local docker stack).
# prod             : you MUST also set SUPABASE_URL and
#                    SUPABASE_SERVICE_ROLE_KEY below.
TARGET=linked

# Only needed when TARGET=prod. Get the service-role key from:
#   Supabase Dashboard → Project Settings → API → service_role secret.
# Treat this like a password. Never commit a filled-in copy of this file.
# SUPABASE_URL="https://xxxxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# ── Company ─────────────────────────────────────────────────────────────────
COMPANY_NAME="Acme Corp"
EMAIL_DOMAIN="acme.com"                # bare domain, lowercase, no '@'/scheme

# Optional company fields
DESCRIPTION=""
MONTHLY_BENEFIT_SUBSIDY="72.00"
CONTRACT_MONTHS="36"
CURRENCY="RON"
EMAIL_PATTERN=""                       # one of: last_middle_first | first_middle_last | first_last | last_first | first_initial_last
CONTACT_EMAIL=""                       # default: contact@$EMAIL_DOMAIN
ESIGNATURES_TEMPLATE_ID=""             # paste a template UUID to enable contracts
ADDRESS=""
ADDRESS_LAT=""
ADDRESS_LON=""
DAYS_IN_OFFICE="5"
LOGO_PATH=""                           # path to a local .png/.jpg/.webp/.svg

# ── HR account ──────────────────────────────────────────────────────────────
HR_EMAIL=""                            # default: hr@$EMAIL_DOMAIN
HR_FIRST_NAME="HR"
HR_LAST_NAME=""                        # default: company name (alphanumeric)
HR_PASSWORD=""                         # leave blank to auto-generate (20 chars)
